# ArXiv论文检索系统环境变量配置

# 小米mimo2.5 API配置
MIMO_API_KEY=your_mimo_api_key_here
MIMO_API_BASE_URL=https://api.mimo.com/v1

# ArXiv API配置（可选）
ARXIV_API_KEY=your_arxiv_api_key_here
ARXIV_API_DELAY=3  # 请求间隔（秒）

# 向量数据库配置
CHROMA_PERSIST_DIRECTORY=./data/embeddings/chroma
CHROMA_COLLECTION_NAME=arxiv_papers

# 嵌入模型配置
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu  # 或 cuda

# 检索配置
RETRIEVAL_TOP_K=10
RETRIEVAL_SIMILARITY_THRESHOLD=0.7

# LLM配置
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TOP_P=0.9

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8501
APP_DEBUG=true

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log